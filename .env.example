# Copy to .env and fill in. Phase 1 (ingestion/metrics) needs none of these.

# --- LLM provider config (Phase 2/3) ---
# Provider-agnostic via LangChain. Default provider is Anthropic (Claude).
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=

# If you switch LLM_PROVIDER=openai, set instead:
# OPENAI_API_KEY=

# --- Pipeline config (optional; defaults shown) ---
# Relative tolerance for the provided-vs-computed rate cross-check (0.02 = 2%)
RATE_MISMATCH_TOLERANCE=0.02
